# Copy this file to tests/dtt/.env and adjust for your local environment.
# This file is NOT committed to version control (.gitignore excludes .env).
#
# In CI the variables below are passed directly to PHPUnit via the
# `terminus remote:drush -- ev` command in pantheon-deploy-multidev.yml,
# so no .env file is needed there.

# Base URL of the running Drupal site to test against.
# For DDEV: https://nysenate.ddev.site
# For a Pantheon multidev: https://pr-123-nysenate-2022.pantheonsite.io
DTT_BASE_URL=https://nysenate.ddev.site

# Chrome DevTools endpoint used by ExistingSiteJavascript tests.
# Only required if you run JS tests; leave blank to skip them.
DTT_API_URL=
